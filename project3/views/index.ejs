<html>
  <head>
    <title>class 13 starter</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Cinzel+Decorative:wght@400;700&display=swap" rel="stylesheet">
    <link href="style.css" rel="stylesheet">
  </head>
  <body>
    <header class="site-header">
      <a href="#big-logo" class="header-CreatureCodex">Creature Codex</a>
      <nav class="header-nav">
        <a href="#about" class="header-link">About</a>
        <a href="#new-creatures" class="header-link header-link-creatures">I got New Creatures!</a>
      </nav>
      <div class="header-search">
        <input type="text" placeholder="Search" />
      </div>
    </header>
    <button id="menu-toggle" class="menu-toggle" type="button" aria-label="Open category menu" aria-expanded="false" aria-controls="creature-sidebar">
      <span class="menu-bars" aria-hidden="true"></span>
      <span class="menu-label">Menu</span>
    </button>
    <aside id="creature-sidebar" class="creature-sidebar" aria-hidden="true">
      <div class="sidebar-header">
        <h2>Menu</h2>
        <button id="menu-close" class="menu-close" type="button" aria-label="Close category menu">❮</button>
      </div>
      <nav class="sidebar-nav" aria-label="Creature categories">
        <div class="sidebar-group">
          <h3>World</h3>
          <ul>
            <li><a href="#">Book</a></li>
            <li><a href="#">Film</a></li>
            <li><a href="#">Animation</a></li>
            <li><a href="#">Myth</a></li>
            <li><a href="#">Self-created World</a></li>
          </ul>
        </div>
        <div class="sidebar-group">
          <h3>Function</h3>
          <ul>
            <li><a href="/creature/yinglong">Weather Control</a></li>
            <li><a href="/creature/tao-tie">Devouring</a></li>
            <li><a href="/creature/nine-tailed-fox">Shapeshifting</a></li>
            <li><a href="/creature/ba-she">Predator</a></li>
          </ul>
        </div>
        <div class="sidebar-group">
          <h3>Shape</h3>
          <ul>
            <li><a href="/creature/yinglong">Dragon</a></li>
            <li><a href="/creature/ba-she">Serpent</a></li>
            <li><a href="/creature/nine-tailed-fox">Fox Spirit</a></li>
            <li><a href="/creature/tao-tie">Mythical Beast</a></li>
          </ul>
        </div>
        <div class="sidebar-group">
          <h3>All Creatures</h3>
          <ul>
            <li><a href="/creature/yinglong">Yinglong</a></li>
            <li><a href="/creature/nine-tailed-fox">Nine-Tailed Fox</a></li>
            <li><a href="/creature/ba-she">BaShe</a></li>
            <li><a href="/creature/tao-tie">TaoTie</a></li>
            <li><a href="/creature/bifang">BiFang</a></li>
            <li><a href="/creature/cerberus">Cerberus</a></li>
            <li><a href="/creature/kraken">Kraken</a></li>
            <li><a href="/creature/medusa">Medusa</a></li>
            <li><a href="/creature/mothman">Mothman</a></li>
          </ul>
        </div>
      </nav>
    </aside>
    <div id="menu-overlay" class="menu-overlay" hidden></div>
    <div id="big-logo" class="logo-center">
      <img src="logo.png" alt="Logo">
    </div>
    <p class="intro">Welcome, Explorer!<br>Creature Codex is a living archive of creatures from myth and imagination.<br>Travel through this strange world, uncover new beings, and add your own discoveries to the codex.</p>
    <div class="intro-button-wrap">
      <a href="#explore" class="intro-button">Explore Now!</a>
    </div>
    <section id="explore" class="explore-section">
      <div class="explore-header-row">
        <h2 class="explore">Explore</h2>
        <button id="explore-refresh" class="explore-refresh" type="button" aria-label="Refresh explore creatures" title="Refresh">
          ↻
        </button>
      </div>
      <div id="explore-grid" class="explore-grid">
        <% exploreCreatures.forEach((creature) => { %>
          <a class="explore-card" href="<%= creature.href %>" aria-label="Open <%= creature.name %> page">
            <img src="<%= creature.image %>" alt="<%= creature.name %>">
            <span class="explore-name"><%= creature.name %></span>
          </a>
        <% }); %>
      </div>
    </section>
    <h3 id="new-creatures" class="i_got_new_creatures">I Got New Creatures!</h3>
    <p class="find_creature">Feel free to fill up the form if you want to add any creature to the condex and we will contact you late for more information by email. It can be a creature that not included in the codex yet, or a creature you created by yourself. Also feel free to directly contact us by email.</p>
    <div class="form-frame">
      <form method="POST" action="/upload" enctype="multipart/form-data">
          <h4 class="email-header">Your Email:</h4>
          <input type="text" name="text" />
          <div class="field-row">
            <div class="field-col">
              <h4 class="name-header">Your Name:</h4>
              <input type="text" name="name" class="name-input" />
            </div>
            <div class="field-col">
              <h4 class="pronoun-header">Your Pronoun:</h4>
              <input type="text" name="pronoun" class="pronoun-input" />
            </div>
          </div>
          <h4 class="form-label">The Name of the Creature:</h4>
          <input type="text" name="creatureName" class="full-input" />
          <h4 class="form-label">Creature Formation:</h4>
          <div class="formation-row">
            <div class="formation-pair">
              <label class="radio-option">
                <input type="radio" name="formation" value="existing" />
                Already created (Novel, myth...)
              </label>
              <input type="text" name="world" class="half-input" placeholder="Which world does it live in?" />
            </div>
            <div class="formation-pair">
              <label class="radio-option">
                <input type="radio" name="formation" value="self" />
                Self Created
              </label>
              <input type="text" name="origin" class="half-input" placeholder="Which world does it live in?"/>
            </div>
          </div>
          <h4 class="form-label">Simple Description of the Creature:</h4>
          <textarea name="description" class="description-box" rows="5"></textarea>
          <div class="submit-container">
            <div>
              <label class="file-label">If you have an image of the creature, you can upload it here:</label>
              <label for="file-upload" class="custom-file-upload"> </label>
              <input id="file-upload" name="theimage" type="file" />
            </div>
            <div>
              <input type="submit" name="submitbutton" value="Submit!" />
              <% if (submitted) { %>
                <div class="submit-message">Submit !</div>
              <% } %>
            </div>
          </div>
      </form>
    </div>
    <section id="about" class="about-bar">
      <div class="about-logo">
        <img src="logo.png" alt="Logo">
      </div>
      <div class="about-columns">
        <div class="about-col">
          <h3>About</h3>
          <p>Creature Codex is a community-driven space for people who enjoy imagining and discovering strange creatures. The goal of the website is to bring together creatures from different sources, including ancient mythology, books, games, and personal creations, into one shared archive. More than just a collection, Creature Codex aims to build a creative community where users can explore creatures. By allowing people to add and share new creatures, the website encourages imagination, collaboration, and world-building, turning the codex into a growing universe created by its community.</p>
        </div>
        <div class="about-col">
          <h3>Contact</h3>
          <p>Email: creature.codex@gmail.com</p>
          <p>Instagram: @CreatureCodex</p>
          <p>Phone Number:+1 56-1344-0264</p>
        </div>
      </div>
    </section>
    <script>
      (function () {
        const refreshButton = document.getElementById('explore-refresh');
        const exploreGrid = document.getElementById('explore-grid');

        if (!refreshButton || !exploreGrid) {
          return;
        }

        const renderExploreCards = (creatures) => {
          exploreGrid.innerHTML = '';

          creatures.forEach((creature) => {
            const card = document.createElement('a');
            card.className = 'explore-card';
            card.href = creature.href;
            card.setAttribute('aria-label', `Open ${creature.name} page`);

            const image = document.createElement('img');
            image.src = creature.image;
            image.alt = creature.name;

            const name = document.createElement('span');
            name.className = 'explore-name';
            name.textContent = creature.name;

            card.appendChild(image);
            card.appendChild(name);
            exploreGrid.appendChild(card);
          });
        };

        refreshButton.addEventListener('click', async () => {
          try {
            refreshButton.disabled = true;
            const response = await fetch('/api/explore');
            const creatures = await response.json();
            renderExploreCards(creatures);
          } catch (error) {
            console.error('Failed to refresh explore cards:', error);
          } finally {
            refreshButton.disabled = false;
          }
        });
      })();

      (function () {
        const menuToggle = document.getElementById('menu-toggle');
        const menuClose = document.getElementById('menu-close');
        const sidebar = document.getElementById('creature-sidebar');
        const overlay = document.getElementById('menu-overlay');

        if (!menuToggle || !menuClose || !sidebar || !overlay) {
          return;
        }

        const openMenu = () => {
          sidebar.classList.add('is-open');
          menuToggle.setAttribute('aria-expanded', 'true');
          sidebar.setAttribute('aria-hidden', 'false');
          overlay.hidden = false;
        };

        const closeMenu = () => {
          sidebar.classList.remove('is-open');
          menuToggle.setAttribute('aria-expanded', 'false');
          sidebar.setAttribute('aria-hidden', 'true');
          overlay.hidden = true;
        };

        menuToggle.addEventListener('click', openMenu);
        menuClose.addEventListener('click', closeMenu);
        overlay.addEventListener('click', closeMenu);

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            closeMenu();
          }
        });
      })();
    </script>
  </body>
</html>